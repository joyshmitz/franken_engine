  "changelog": [
    {
      "version": "0.1.0",
      "rationale": "Create a fail-closed, machine-readable contract for V8-supremacy language before publication gates rely on it.",
      "impact_assessment": "Adds explicit matrix cells, statistical thresholds, and downgrade rules so universal language cannot outrun evidence.",
      "compatibility_notes": "Additive contract; existing benchmark and docs gates may consume it without changing their public surface.",
      "changed_at_utc": "2026-03-07T00:00:00Z"
    }
  ],
