  "published_language_contract": {
    "phrase_classes": [
      "universal_dominance",
      "scoped_observed",
      "target",
      "hypothesis"
    ],
    "forbidden_universal_phrases": [
      "beats V8 across the board",
      "across the board",
      "faster than V8 in every case",
      "universally superior to V8"
    ],
    "required_qualifier_terms": [
      "observed",
      "target",
      "hypothesis"
    ],
    "required_artifact_fields": [
      "scope",
      "environment",
      "artifact_path",
      "publication_date",
      "revision"
    ],
    "downgrade_rules": [
      {
        "when_missing": "any required family missing_or_mixed",
        "require_phrase_class": "scoped_observed"
      },
      {
        "when_missing": "tail_or_memory_side_constraint_failed",
        "require_phrase_class": "scoped_observed"
      },
      {
        "when_missing": "board_incomplete_but_program_defined",
        "require_phrase_class": "target"
      },
      {
        "when_missing": "claim_speculative_without_green_cells",
        "require_phrase_class": "hypothesis"
      }
    ]
  },
